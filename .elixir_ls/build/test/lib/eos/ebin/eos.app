{application,eos,
             [{compile_env,[{eos,['Elixir.EosWeb.Endpoint',code_reloader],
                                 error},
                            {eos,['Elixir.EosWeb.Endpoint',debug_errors],
                                 error},
                            {eos,['Elixir.EosWeb.Endpoint',force_ssl],error},
                            {eos,['Elixir.EosWeb.Gettext'],error},
                            {eos,[dev_routes],error}]},
              {optional_applications,[]},
              {applications,[kernel,stdlib,elixir,logger,runtime_tools,
                             phoenix,phoenix_html,phoenix_live_view,lazy_html,
                             phoenix_live_dashboard,req,k8s,telemetry_metrics,
                             telemetry_poller,gettext,jason,dns_cluster,
                             bandit]},
              {description,"eos"},
              {modules,['Elixir.Eos','Elixir.Eos.Application',
                        'Elixir.Eos.Broker.Client',
                        'Elixir.Eos.Broker.SubscriptionManager',
                        'Elixir.Eos.K8s.Client','Elixir.Eos.K8s.Operator',
                        'Elixir.Eos.K8s.PluginController',
                        'Elixir.Eos.Plugins.Registry',
                        'Elixir.Eos.Plugins.Token','Elixir.EosWeb',
                        'Elixir.EosWeb.BrokerLive.Index',
                        'Elixir.EosWeb.Channels.PluginChannel',
                        'Elixir.EosWeb.Channels.PluginSocket',
                        'Elixir.EosWeb.Channels.PluginV2CompatSerializer',
                        'Elixir.EosWeb.ConnCase',
                        'Elixir.EosWeb.CoreComponents',
                        'Elixir.EosWeb.DashboardLive',
                        'Elixir.EosWeb.Endpoint','Elixir.EosWeb.ErrorHTML',
                        'Elixir.EosWeb.ErrorJSON','Elixir.EosWeb.Gettext',
                        'Elixir.EosWeb.HealthController',
                        'Elixir.EosWeb.Layouts',
                        'Elixir.EosWeb.NotificationController',
                        'Elixir.EosWeb.PageController',
                        'Elixir.EosWeb.PageHTML',
                        'Elixir.EosWeb.PluginLive.Index',
                        'Elixir.EosWeb.PluginLive.Show',
                        'Elixir.EosWeb.Plugs.BasicAuth',
                        'Elixir.EosWeb.Router','Elixir.EosWeb.Telemetry']},
              {registered,[]},
              {vsn,"0.1.0"},
              {mod,{'Elixir.Eos.Application',[]}}]}.
